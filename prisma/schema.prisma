generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            Int            @id @default(autoincrement())
  name          String
  slug          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  isDeleted     Boolean        @default(false)
  nextSequence  Int            @default(1)
  admins        Admin[]
  doctors       Doctor[]
  registrations Registration[]
  tests         Test[]
  users         User[]
  parameters     Parameter[]
  testParameters TestParameter[]
  testFormulas   TestFormula[]
  interpretationRules InterpretationRule[]
}

model SuperAdmin {
  id        Int                 @id @default(autoincrement())
  name      String
  email     String              @unique
  password  String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  sessions  SuperAdminSession[]
  trackings SuperAdminTracking[]
}

model SuperAdminSession {
  id           Int        @id @default(autoincrement())
  superAdminId Int
  token        String     @unique @db.VarChar(500)
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@index([superAdminId], map: "SuperAdminSession_superAdminId_fkey")
}

model User {
  id                       Int           @id @default(autoincrement())
  name                     String
  email                    String        @unique
  password                 String?
  provider                 String        @default("credentials")
  googleId                 String?       @unique
  roleId                   Int           @default(2)
  isEmailVerified          Boolean       @default(false)
  isApproved               Boolean       @default(false)
  rejected                 Boolean       @default(false)
  verificationToken        String?       @db.VarChar(255)
  verificationTokenExpires DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  workspaceId              Int?
  expireAt                 DateTime?
  startAt                  DateTime?
  role                     UserRole      @relation(fields: [roleId], references: [id])
  workspace                Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions                 UserSession[]

  @@index([roleId], map: "User_roleId_fkey")
  @@index([workspaceId], map: "User_workspaceId_fkey")
}

model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "UserSession_userId_fkey")
}

model UserRole {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  users       User[]
  permissions UserRolePermission[]
}

model UserRolePermission {
  id         Int      @id @default(autoincrement())
  roleId     Int
  permission String
  role       UserRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

model Admin {
  id                         Int            @id @default(autoincrement())
  name                       String
  email                      String         @unique
  password                   String
  provider                   String         @default("credentials")
  roleId                     Int            @default(1)
  isEmailVerified            Boolean        @default(true)
  isApproved                 Boolean        @default(true)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  footerMargin               Int            @default(100)
  framePdfUrl                String?        @db.VarChar(500)
  headerMargin               Int            @default(140)
  useFrameDefault            Boolean        @default(true)
  isActive                   Boolean        @default(true)
  workspaceId                Int?
  expireAt                   DateTime?
  startAt                    DateTime?
  authorizedSignatoryDegree1 String?
  authorizedSignatoryDegree2 String?
  authorizedSignatoryName1   String?
  authorizedSignatoryName2   String?
  companyName                String?
  mobileNumber               String?
  role                       AdminRole      @relation(fields: [roleId], references: [id])
  workspace                  Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  address                    AdminAddress?
  sessions                   AdminSession[]
  trackings                  AdminTracking[]
  registrations              Registration[] @relation("AdminRegistrations")

  @@index([roleId])
  @@index([workspaceId], map: "Admin_workspaceId_fkey")
}

model AdminSession {
  id        Int      @id @default(autoincrement())
  adminId   Int
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId], map: "AdminSession_adminId_fkey")
}

model AdminRole {
  id          Int                   @id @default(autoincrement())
  name        String                @unique
  deletedAt   DateTime?
  isDeleted   Boolean               @default(false)
  admins      Admin[]
  permissions AdminRolePermission[]
}

model AdminRolePermission {
  id         Int       @id @default(autoincrement())
  roleId     Int
  permission String
  role       AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

model Doctor {
  id                  Int               @id @default(autoincrement())
  name                String
  code                String?
  lastPaid            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workspaceId         Int?
  incentivePercent    Decimal           @default(0.00) @db.Decimal(5, 2)
  isDeleted           Boolean           @default(false)
  deletedAt           DateTime?
  address             String?
  clinicName          String?
  degree              String?
  workspace           Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  registrations       Registration[]    @relation("RefBy")
  secondRegistrations Registration[]    @relation("SecondRef")
  incentiveHistory    DoctorIncentive[]

  @@unique([workspaceId, code])
}

model Test {
  id            Int                @id @default(autoincrement())
  name          String
  code          String?
  price         Decimal            @db.Decimal(10, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  isProcessed   Boolean            @default(false)
  workspaceId   Int?
  isCustomized  Boolean            @default(false)
  defaultUpdatedAt DateTime?
  deletedAt     DateTime?
  isDeleted     Boolean            @default(false)
  departmentId  Int?
  department    TestDepartment?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  registrations RegistrationTest[]
  workspace     Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parameters    TestParameter[]
  formulas      TestFormula[]
  interpretationRules InterpretationRule[]

  @@unique([workspaceId, code])
  @@index([departmentId])
}

model Registration {
  id               Int                   @id @default(autoincrement())
  billOn           String                @default("Patient Rate")
  mobileNo         String
  labId            String
  regNo            String                @unique
  date             DateTime              @default(now())
  title            String
  name             String
  city             String                @default("-NA-")
  age              Float
  ageUnit          String                @default("Year")
  gender           String
  refById          Int?
  secondRefId      Int?
  remark           String?
  colType          String                @default("Camp")
  expRptDate       DateTime?
  sampleDate       DateTime?
  sampleNo         String?
  sampleBy         String                @default("-NA-")
  paymentMode      String                @default("Cash")
  paymentRefNo     String?
  totalAmount      Decimal               @default(0.00) @db.Decimal(10, 2)
  collectionCharge Decimal               @default(0.00) @db.Decimal(10, 2)
  discountPercent  Decimal               @default(0.00) @db.Decimal(10, 2)
  discountAmount   Decimal               @default(0.00) @db.Decimal(10, 2)
  receivedAmount   Decimal               @default(0.00) @db.Decimal(10, 2)
  dueAmount        Decimal               @default(0.00) @db.Decimal(10, 2)
  refByIncentivePercent     Decimal       @default(0.00) @db.Decimal(5, 2)
  secondRefIncentivePercent Decimal       @default(0.00) @db.Decimal(5, 2)
  stickerCount     Int                   @default(1)
  barcode          String?
  status           String                @default("Pending")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  workspaceId      Int?
  adminId          Int?
  deletedAt        DateTime?
  isDeleted        Boolean               @default(false)
  results          PatientResult[]
  refBy            Doctor?               @relation("RefBy", fields: [refById], references: [id])
  secondRef        Doctor?               @relation("SecondRef", fields: [secondRefId], references: [id])
  workspace        Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  admin            Admin?                @relation("AdminRegistrations", fields: [adminId], references: [id])
  payments         RegistrationPayment[]
  tests            RegistrationTest[]

  @@unique([workspaceId, labId])
  @@index([date])
  @@index([mobileNo])
  @@index([refById], map: "Registration_refById_fkey")
  @@index([secondRefId], map: "Registration_secondRefId_fkey")
  @@index([workspaceId])
  @@index([adminId])
}

model RegistrationTest {
  registrationId Int
  testId         Int
  price          Decimal      @default(0.00) @db.Decimal(10, 2)
  assessNo       String?
  collectedBy    String       @default("-NA-")
  expense        Decimal      @default(0.00) @db.Decimal(10, 2)
  pathologist    String       @default("-NA-")
  product        String       @default("-NA-")
  sampleBarcode  String?
  sampleRemark   String?
  sampleStatus   String       @default("Pending")
  sendTo         String       @default("-NA-")
  interpretation String?      @db.Text
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  test           Test         @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([registrationId, testId])
  @@index([testId], map: "RegistrationTest_testId_fkey")
}

model Parameter {
  id                 Int             @id @default(autoincrement())
  name               String
  code               String?
  unit               String?
  minValMale         Float?
  maxValMale         Float?
  normalRangeMale    String?
  minValFemale       Float?
  maxValFemale       Float?
  normalRangeFemale  String?
  minValBaby         Float?
  maxValBaby         Float?
  normalRangeBaby    String?
  normalRangeDefault String?
  criticalMinValMale     Float?
  criticalMaxValMale     Float?
  criticalMinValFemale   Float?
  criticalMaxValFemale   Float?
  criticalMinValBaby     Float?
  criticalMaxValBaby     Float?
  criticalMinValDefault  Float?
  criticalMaxValDefault  Float?
  borderlineMinValMale     Float?
  borderlineMaxValMale     Float?
  borderlineMinValFemale   Float?
  borderlineMaxValFemale   Float?
  borderlineMinValBaby     Float?
  borderlineMaxValBaby     Float?
  borderlineMinValDefault  Float?
  borderlineMaxValDefault  Float?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  workspaceId        Int?
  workspace          Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  testMappings       TestParameter[]
  testFormulas       TestFormula[]
  interpretationRules InterpretationRule[]

  @@unique([workspaceId, name])
  @@index([workspaceId], map: "Parameter_workspaceId_fkey")
}

model TestParameter {
  id           Int             @id @default(autoincrement())
  testId       Int
  order        Int             @default(1)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  isDeleted    Boolean         @default(false)
  parameterId  Int
  workspaceId  Int?
  editable     Boolean         @default(true)
  isCalculated Boolean         @default(false)
  decimalPlace Int             @default(2)
  roundingMethod String          @default("HALF_UP")
  section      String?
  unit         String?
  isHeader     Boolean         @default(false)
  parentId     Int?            // DB id of the parent isHeader TestParameter; null = standalone or is a header
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  results      PatientResult[]
  parameter    Parameter       @relation(fields: [parameterId], references: [id], onDelete: Cascade)
  test         Test            @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([parameterId], map: "TestParameter_parameterId_fkey")
  @@index([testId], map: "TestParameter_testId_fkey")
  @@index([workspaceId], map: "TestParameter_workspaceId_fkey")
}

model PatientResult {
  id              Int           @id @default(autoincrement())
  registrationId  Int
  testParameterId Int
  value           String
  flag            String?
  interpretation  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  registration    Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  testParameter   TestParameter @relation(fields: [testParameterId], references: [id], onDelete: Cascade)

  @@unique([registrationId, testParameterId])
  @@index([testParameterId], map: "PatientResult_testParameterId_fkey")
}

model Lead {
  id        Int      @id @default(autoincrement())
  contact   String   @unique
  type      String
  createdAt DateTime @default(now())
}

model AdminAddress {
  id        Int      @id @default(autoincrement())
  address1  String?
  address2  String?
  city      String?
  state     String?
  pincode   String?
  country   String?
  latitude  Float?
  longitude Float?
  adminId   Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model RegistrationPayment {
  id             Int          @id @default(autoincrement())
  registrationId Int
  amount         Decimal      @db.Decimal(10, 2)
  paymentMode    String       @default("Cash")
  paymentRefNo   String?
  remark         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId], map: "RegistrationPayment_registrationId_fkey")
}

model LeadContact {
  id           Int       @id @default(autoincrement())
  name         String
  emailOrPhone String
  message      String?   @db.Text
  isRead       Boolean   @default(false)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AdminTracking {
  id            Int      @id @default(autoincrement())
  sessionId     String   @unique
  startUTC      DateTime
  ENDUTC        DateTime
  mode          String
  durationInMin Float
  adminId       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  admin         Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId], map: "AdminTracking_adminId_fkey")
}

model SuperAdminTracking {
  id            Int         @id @default(autoincrement())
  sessionId     String      @unique
  startUTC      DateTime
  ENDUTC        DateTime
  mode          String
  durationInMin Float
  superAdminId  Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  superAdmin    SuperAdmin? @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@index([superAdminId], map: "SuperAdminTracking_superAdminId_fkey")
}

model TestDepartment {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tests     Test[]
}

model TestFormula {
  id                Int             @id @default(autoincrement())
  workspaceId       Int?
  testId            Int
  outputParameterId Int
  formula           String          @db.Text
  description       String?
  name              String?
  version           Int             @default(1)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspace         Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  test              Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  outputParameter   Parameter       @relation(fields: [outputParameterId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, testId, outputParameterId])
  @@index([testId])
  @@index([outputParameterId])
  @@index([workspaceId])
}

model InterpretationRule {
  id             Int          @id @default(autoincrement())
  workspaceId    Int?
  testId         Int
  parameterId    Int
  condition      String       @db.Text
  interpretation String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  test           Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  parameter      Parameter    @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([parameterId])
  @@index([workspaceId])
}

model DoctorIncentive {
  id               Int      @id @default(autoincrement())
  doctorId         Int
  incentivePercent Decimal  @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  doctor           Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}
